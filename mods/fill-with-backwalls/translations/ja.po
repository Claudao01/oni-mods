msgctxt "FillWithBackwalls.STRINGS.UI.FILL_CAVITY.NAME"
msgid "Fill cavity"
msgstr "空洞を埋める"

msgctxt "FillWithBackwalls.STRINGS.UI.FILL_CAVITY.TOOLTIP"
msgid "Fills the entire enclosed cavity with the selected backwall blueprint, material, and facade."
msgstr "選択した背景壁の設計図、素材、外観で閉鎖された空洞全体を埋めます。"

msgctxt "FillWithBackwalls.STRINGS.UI.OPTIONS.MAX_CAVITY_SIZE.NAME"
msgid "Maximum cavity size"
msgstr "空洞の最大サイズ"

msgctxt "FillWithBackwalls.STRINGS.UI.OPTIONS.MAX_CAVITY_SIZE.TOOLTIP"
msgid "Maximum number of cells that can be filled with one click."
msgstr "1 回のクリックで埋められるセルの最大数です。"

msgctxt "FillWithBackwalls.STRINGS.UI.FEEDBACK.NO_MATERIAL"
msgid "No material is selected for this backwall."
msgstr "この背景壁の素材が選択されていません。"

msgctxt "FillWithBackwalls.STRINGS.UI.FEEDBACK.CLOSED_CAVITY_REQUIRED"
msgid "Select a cell inside an enclosed cavity."
msgstr "閉鎖された空洞内のセルを選択してください。"

msgctxt "FillWithBackwalls.STRINGS.UI.FEEDBACK.CAVITY_TOO_LARGE"
msgid "Cavity too large ({0} cells). Current limit: {1}."
msgstr "空洞が大きすぎます（{0} セル）。現在の上限: {1}。"

msgctxt "FillWithBackwalls.STRINGS.UI.FEEDBACK.SUMMARY"
msgid "{0} build orders queued, {1} facades updated, {2} cells skipped."
msgstr "建設命令を {0} 件作成し、外観を {1} 件更新、セルを {2} 個スキップしました。"
